{
  "name": "sentimony-images",
  "private": true,
  "type": "module",
  "scripts": {
    "check:images": "node scripts/check-images.mjs",
    "check:svg": "node scripts/check-svg-colors.mjs",
    "typecheck": "vue-tsc --noEmit",
    "test:pages": "node scripts/smoke-pages.mjs",
    "fix:configs": "node scripts/fix-configs.mjs",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy:stage": "npx -y dotenv-cli@11 -e .env/.env.local -e .env/.env -- npx -y netlify-cli@26 deploy --alias stage --context deploy-preview",
    "deploy:prod": "npx -y dotenv-cli@11 -e .env/.env.local -e .env/.env -- npx -y netlify-cli@26 deploy --prod --context production"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "playwright": "^1.61.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vue-tsc": "^3.3.7"
  },
  "dependencies": {
    "@unhead/vue": "^3.1.7",
    "lucide-vue-next": "^1.0.0",
    "v-wave": "^3.1.1",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "engines": {
    "node": ">=24.15.0",
    "npm": ">=11.12.0"
  }
}
